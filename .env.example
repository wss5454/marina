# --- Database ---
POSTGRES_USER=marina
POSTGRES_PASSWORD=marina_dev_password
POSTGRES_DB=marina_portal
DATABASE_URL=postgresql+asyncpg://marina:marina_dev_password@postgres:5432/marina_portal

# --- Redis (Celery) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- App URLs (used in emails / CORS) ---
PUBLIC_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# Comma-separated emails for "new request" manager alerts
MANAGER_ALERT_EMAILS=

# --- SendGrid (email) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_TEMPLATE_PREFIX=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# --- S3-compatible storage (MinIO local) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=marina-portal
S3_REGION=us-east-1
S3_USE_SSL=false

# --- Wallace bridge ---
WALLACE_EXPORT_DIR=/data/wallace_exports
WALLACE_SYNC_INTERVAL_SECONDS=900
WALLACE_UPLOAD_API_KEY=change-me-upload-key

# --- Frontend (Next.js build) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
