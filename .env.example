# --- Database ---
POSTGRES_USER=marina
POSTGRES_PASSWORD=marina_dev_password
POSTGRES_DB=marina_portal
DATABASE_URL=postgresql+asyncpg://marina:marina_dev_password@postgres:5432/marina_portal

# --- Redis (Celery) ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- App URLs (used in emails / CORS) ---
PUBLIC_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000

# Comma-separated emails for "new request" manager alerts
MANAGER_ALERT_EMAILS=

# --- SendGrid (email) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_TEMPLATE_PREFIX=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# --- S3-compatible storage (MinIO local) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=marina-portal
S3_REGION=us-east-1
S3_USE_SSL=false

# --- Wallace bridge ---
WALLACE_EXPORT_DIR=/data/wallace_exports
WALLACE_SYNC_INTERVAL_SECONDS=900
WALLACE_UPLOAD_API_KEY=change-me-upload-key

# --- Frontend (Next.js build) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Multi-tenant marina branding ---
DEFAULT_MARINA_SLUG=your-dealership-name
DEFAULT_MARINA_NAME=Your Dealership Name
DEFAULT_MARINA_CONTACT_EMAIL=service@example.com
DEFAULT_MARINA_CONTACT_PHONE=(410) 555-0100

# --- Bootstrap test users ---
# Visit GET /api/v1/setup/bootstrap?key=<BOOTSTRAP_API_KEY> after deploy (browser-friendly).
BOOTSTRAP_API_KEY=change-me-bootstrap-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
TEST_CUSTOMER_EMAIL=customer@example.com
TEST_CUSTOMER_PASSWORD=changeme123
# Optional customer profile / boat for the test account
TEST_CUSTOMER_FIRST_NAME=Test
TEST_CUSTOMER_LAST_NAME=Customer
TEST_CUSTOMER_BOAT_MAKE=Sea Ray
TEST_CUSTOMER_BOAT_MODEL=Sundancer
TEST_CUSTOMER_BOAT_YEAR=2020

# --- Multi-tenant / payments (stub) ---
GRAVITY_STUB_MODE=true
GRAVITY_WEBHOOK_SECRET=change-me-webhook-secret
NEXT_PUBLIC_MARINA_SLUG=your-dealership-name
NEXT_PUBLIC_MARINA_NAME=Your Dealership Name
NEXT_PUBLIC_MARINA_SUBTITLE=Service & storage portal
